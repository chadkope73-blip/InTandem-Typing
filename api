export default async function handler(req, res) {
  if (req.method !== "POST") {
    return res.status(405).json({ error: "Method not allowed" });
  }

  const {
    countryName = "United States",
    language = "English",
    topic = "AI Learning",
    minutes = 1
  } = req.body || {};

  const apiKey = process.env.STORY_API_KEY;
  const baseUrl = process.env.STORY_API_BASE_URL;
  const model = process.env.STORY_MODEL;

  if (!apiKey || !baseUrl || !model) {
    return res.status(500).json({
      error: "Missing STORY_API_KEY, STORY_API_BASE_URL, or STORY_MODEL"
    });
  }

  const targetWords = minutes === 1 ? 180 : minutes === 3 ? 420 : 700;

  const prompt = `
Generate one original typing-practice passage for a human-developed, AI-assisted online learning tool.

Requirements:
- Topic: ${topic}
- Language: ${language}
- Country context: ${countryName}
- Tone: hopeful, practical, human-centered
- Style influence: broad modern sci-fi, fantasy, exploration, role-playing adventure energy
- Audience: adult builders, students, higher education learners, modern makers
- Teach useful ideas about AI while remaining readable for typing practice
- Output exactly 3 paragraphs
- Target about ${targetWords} words total
- No violence, no gore, no illegal activity, no sexual content, no fearmongering
- No copyrighted characters, no named franchises, no author imitation
- Clear punctuation and readable prose
- Return plain text only
`.trim();

  try {
    const response = await fetch(`${baseUrl.replace(/\/$/, "")}/responses`, {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
        "Authorization": `Bearer ${apiKey}`
      },
      body: JSON.stringify({
        model,
        input: prompt
      })
    });

    if (!response.ok) {
      const text = await response.text();
      return res.status(500).json({ error: "Model request failed", detail: text });
    }

    const data = await response.json();

    let story = "";

    if (typeof data.output_text === "string") {
      story = data.output_text;
    } else if (Array.isArray(data.output)) {
      story = data.output
        .flatMap(item => item.content || [])
        .filter(part => part.type === "output_text" && typeof part.text === "string")
        .map(part => part.text)
        .join("\n");
    }

    story = story.trim();

    if (!story) {
      return res.status(500).json({ error: "No story text returned" });
    }

    return res.status(200).json({ story });
  } catch (error) {
    return res.status(500).json({
      error: "Unexpected server error",
      detail: error.message
    });
  }
}
